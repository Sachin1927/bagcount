# Virtual environment
.venv/

# Large video files in data/ — place your own in data/raw/
data/raw/*.mp4
data/raw/*.avi
data/raw/*.mov
data/processed/*.mp4
data/processed/*.avi
data/processed/*.pdf

# Keep folder structure visible on GitHub
!data/raw/.gitkeep
!data/processed/.gitkeep

# Model weights — downloaded automatically by Ultralytics on first run
models/*.pt
models/*.onnx

# Keep models folder visible
!models/.gitkeep

# assets/ is tracked (demo videos for README)

# Python
__pycache__/
*.py[cod]

# OS
.DS_Store
Thumbs.db
assets/
